# =============================================================================
# stagehand-social-sdk environment variables
# Copy this file to .env and fill in only what you use.
# =============================================================================

# --- Required: Browserbase ---------------------------------------------------
# Sign up at https://browserbase.com and grab your API key + project ID.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Required: LLM (pick one) ------------------------------------------------
# Stagehand uses an LLM to interpret act() / extract() instructions.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Optional: SDK behavior --------------------------------------------------
# STAGEHAND_SOCIAL_HEADLESS=true                # default: true
# STAGEHAND_SOCIAL_LOG_LEVEL=info               # debug | info | warn | error
# STAGEHAND_SOCIAL_SESSION_DIR=~/.stagehand-social  # where context refs are cached

# =============================================================================
# Per-platform credentials — set only what you actually use.
# =============================================================================

# --- Instagram ---------------------------------------------------------------
STAGEHAND_SOCIAL_INSTAGRAM_USERNAME=
STAGEHAND_SOCIAL_INSTAGRAM_PASSWORD=
STAGEHAND_SOCIAL_INSTAGRAM_TOTP_SECRET=

# --- TikTok ------------------------------------------------------------------
STAGEHAND_SOCIAL_TIKTOK_USERNAME=
STAGEHAND_SOCIAL_TIKTOK_PASSWORD=
STAGEHAND_SOCIAL_TIKTOK_TOTP_SECRET=

# --- X / Twitter -------------------------------------------------------------
STAGEHAND_SOCIAL_X_USERNAME=
STAGEHAND_SOCIAL_X_PASSWORD=
STAGEHAND_SOCIAL_X_TOTP_SECRET=

# --- Facebook ----------------------------------------------------------------
STAGEHAND_SOCIAL_FACEBOOK_USERNAME=
STAGEHAND_SOCIAL_FACEBOOK_PASSWORD=
STAGEHAND_SOCIAL_FACEBOOK_TOTP_SECRET=

# --- YouTube (Google account) ------------------------------------------------
STAGEHAND_SOCIAL_YOUTUBE_USERNAME=
STAGEHAND_SOCIAL_YOUTUBE_PASSWORD=
STAGEHAND_SOCIAL_YOUTUBE_TOTP_SECRET=

# --- LinkedIn ----------------------------------------------------------------
STAGEHAND_SOCIAL_LINKEDIN_USERNAME=
STAGEHAND_SOCIAL_LINKEDIN_PASSWORD=
STAGEHAND_SOCIAL_LINKEDIN_TOTP_SECRET=

# --- Threads (uses Instagram credentials by default) -------------------------
STAGEHAND_SOCIAL_THREADS_USERNAME=
STAGEHAND_SOCIAL_THREADS_PASSWORD=
STAGEHAND_SOCIAL_THREADS_TOTP_SECRET=

# --- Generic site adapter (per-account, set the SITE prefix yourself) --------
# Example for a custom site identified as "myapp":
# STAGEHAND_SOCIAL_GENERIC_MYAPP_USERNAME=
# STAGEHAND_SOCIAL_GENERIC_MYAPP_PASSWORD=
